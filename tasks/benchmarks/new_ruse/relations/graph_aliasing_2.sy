{
    "version": 2,
    "import": [
      "../../../classes/ruse/graph.ts"
    ],
    "returnType": "Int",
    "variables": {
      "graph1": "GraphNode",
      "graph2": "GraphNode",
      "graph3": "GraphNode",
      "graph1_2": "*graph1",
      "graph2_2": "*graph2",
      "graph3_2": "*graph3",
      "graph1_3": "*graph1",
      "graph2_3": "*graph2",
      "graph3_3": "*graph3"
    },
    "intLiterals": [],
    "examples": [
      {
        "input": {
          "graph1": {
            "@js": "new GraphNode(5, new GraphNode(6))"
          },
          "graph2": {
            "@js": "new GraphNode(6, new GraphNode(7))"
          },
          "graph3": {
            "@js": "new GraphNode(7, new GraphNode(5))"
          }
        },
        "output": 18
      }
    ],
    "solution": {
      "has_side_effects": "no",
      "expected": [
        "graph1.value + graph2.value + graph3.value",
        "graph1.value + graph3.value + graph2.value",
        "graph2.value + graph1.value + graph3.value",
        "graph2.value + graph3.value + graph1.value",
        "graph3.value + graph1.value + graph2.value",
        "graph3.value + graph2.value + graph1.value"
      ]
    }
  }
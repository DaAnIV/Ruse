{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'ruse benchmarks'",
            "cargo": {
                "args": [
                    "build",
                    "--package=ruse_benchmarks"
                ]
            },
            "args": [
                "run",
                "-b", "benchmarks/tasks/simple/complex_user.sy",
                "-o", "failed/failed2.json",
                "-t", "5000",
                "-vvv",
            ],
            "cwd": "${workspaceFolder}"
        }
    ]
}
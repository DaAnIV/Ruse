{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug running benchmark",
            "cwd": "${workspaceFolder}",
            "cargo": {
                "args": [
                    "build",
                    "--package=Ruse",
                    "--features",
                    "trace_evaluations trace_embeddings"
                ]
            },
            "env": {
                "RUST_BACKTRACE": "short",
                "RUSTC_TOOLCHAIN": "/home/biber.barak/.rustup/toolchains/stable-x86_64-unknown-linux-gnu"
            },
            "args": [
                "run",
                "-b",
                "benchmarks/tasks/simple/seq.sy",
                "-o",
                "results/debug_results.json",
                "--log",
                "results/debug_log.json",
                "-t",
                "5000",
                // "--single-thread",
                "--workers-count",
                "1",
                "-vvv",
                "--max-iterations",
                "3",
                "--max-context-depth",
                "3",
            ],
            "sourceLanguages": [
                "rust"
            ],
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug ts parsing",
            "cargo": {
                "args": [
                    "build",
                    "--package=Ruse"
                ]
            },
            "args": [
                "print-opcodes",
                "--print-js-code",
                "-o",
                "-t",
                "benchmarks/tasks/classes/simple_tree.ts",
            ],
            "cwd": "${workspaceFolder}"
        },
    ],
        }
    ]
}
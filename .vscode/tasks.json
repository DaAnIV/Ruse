{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "$HOME/.cargo/bin/cargo build",
			"problemMatcher": "$rustc",
			"group": {
				"kind": "build",
				"isDefault": true
			},
        },
        {
            "label": "build release",
            "type": "shell",
            "command": "$HOME/.cargo/bin/cargo build --profile release",
			"problemMatcher": "$rustc",
			"group": {
				"kind": "build",
				"isDefault": true
			},
        },
        {
            "label": "build profiling",
            "type": "shell",
            "command": "$HOME/.cargo/bin/cargo build --profile profiling",
			"problemMatcher": "$rustc",
			"group": {
				"kind": "build",
				"isDefault": true
			},
        },
        {
            "label": "build test",
            "type": "shell",
            "command": "$HOME/.cargo/bin/cargo build --profile test",
			"problemMatcher": "$rustc",
			"group": {
				"kind": "build",
				"isDefault": true
			},
        }
    ]
}